FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "system";
    object      controlDict;
}


application     rhoCentralFoam;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         3.0;

deltaT          1e-10;

writeControl    adjustableRunTime;

writeInterval   0.2;
    purgeWrite      3;

cycleWrite      0;

writeFormat     ascii;

writePrecision  15;

writeCompression off;

timeFormat      general;

timePrecision   6;

adjustTimeStep  yes;

maxCo           0.2;

maxDeltaT       1;

functions
{
}
